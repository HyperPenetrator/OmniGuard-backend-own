# ==============================================================
# OmniGuard Backend — Environment Configuration
# Copy this file to .env and fill in real values
# NEVER commit .env to version control
# ==============================================================

# ── Server ──────────────────────────────────────────────────
NODE_ENV=development
PORT=3001
FRONTEND_ORIGIN=http://localhost:5173

# ── JWT ─────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace_with_256_bit_secret_minimum_64_hex_chars
JWT_EXPIRES_IN=30m
JWT_REFRESH_SECRET=replace_with_different_256_bit_secret
JWT_REFRESH_EXPIRES_IN=7d

# ── Firebase ─────────────────────────────────────────────────
# Get these from Firebase Console > Project Settings > Service Accounts > Generate New Private Key
FIREBASE_PROJECT_ID=omniguard-backend-own
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-fbsvc@omniguard-backend-own.iam.gserviceaccount.com
